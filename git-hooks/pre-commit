#!/bin/sh
# git-hooks/pre-commit — my-claude-plugins 레포 전용 pre-commit 훅
# core.hooksPath = git-hooks 설정으로 이 파일이 실행됨
#
# 검증 순서:
#   1. CHANGELOG.md 갱신 여부 (글로벌 훅과 동일 로직)
#   2. SESSION-DB.md 변경 이력 표 갱신 여부 (session-db 소스 변경 시)
#   3. marketplace.json ↔ plugin.json 버전 동기화

set -e

# ── 1. CHANGELOG.md 검증 ─────────────────────────────────────────────────────
STAGED=$(git -c core.quotepath=false diff --cached --name-only)

# _handoff/ 전용 커밋은 CHANGELOG 검증 스킵
NON_HANDOFF=$(echo "$STAGED" | grep -v "^_handoff/" || true)
if [ -z "$NON_HANDOFF" ]; then
  exit 0
fi

# 서브폴더 CHANGELOG.md 차단
SUBDIR_CHANGELOG=$(echo "$STAGED" | grep -E ".+/CHANGELOG\.md$" || true)
if [ -n "$SUBDIR_CHANGELOG" ]; then
  echo ""
  echo "✗ 커밋 차단: 서브폴더에 CHANGELOG.md가 포함되어 있습니다."
  echo "  $SUBDIR_CHANGELOG"
  echo ""
  echo "  규칙: CHANGELOG.md는 프로젝트 루트에만 존재해야 합니다."
  echo "  조치: git rm --cached <파일> 후 루트 CHANGELOG.md를 사용하세요."
  echo ""
  exit 1
fi

# CHANGELOG.md가 staged → 통과
if echo "$STAGED" | grep -q "^CHANGELOG\.md$"; then
  : # 통과, 아래 검증 계속
elif [ ! -f "CHANGELOG.md" ]; then
  # CHANGELOG.md 없으면 템플릿으로 자동 생성
  TEMPLATE="C:/Users/ahnbu/CHANGELOG_TEMPLATE.md"
  if [ -f "$TEMPLATE" ]; then
    cp "$TEMPLATE" CHANGELOG.md
  else
    printf '# CHANGELOG\n\n## 이력\n\n| 날짜 | 타입 | 버전 | 변경 내용 |\n|------|------|------|----------|\n' > CHANGELOG.md
  fi
  git add CHANGELOG.md
  echo ""
  echo "✔ CHANGELOG.md가 없어 템플릿으로 자동 생성했습니다."
  echo ""
else
  echo ""
  echo "✗ 커밋 차단: CHANGELOG.md가 이 커밋에 포함되지 않았습니다."
  echo ""
  echo "  규칙: 커밋별로 해당 커밋의 변경 내용만 CHANGELOG에 기록하라."
  echo "        일괄 수정 후 개별 커밋 금지."
  echo ""
  echo "  조치: 변경 내용을 CHANGELOG.md에 추가 → git add CHANGELOG.md"
  echo ""
  exit 1
fi

# ── 2. SESSION-DB.md 변경 이력 검증 ──────────────────────────────────────────
node "$(dirname "$0")/check-session-db-doc.js"

# ── 3. 버전 동기화 검증 ───────────────────────────────────────────────────────
node "$(dirname "$0")/check-version-sync.js.bak"
